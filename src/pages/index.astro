---
import Layout from "@/layouts/Layout.astro";
import ServiceCard from "@/components/ServiceCard.svelte";
import ProjectCard from "@/components/ProjectCard.svelte";
import ContactSection from "@/components/ContactSection.svelte";
import Collaborators from "@/components/Collaborators.svelte";

const services = [
  {
    title: "Cimentaciones Profundas",
    description:
      "Si el suelo es una pesadilla, nosotros lo convertiremos en un búnker. Ejecutamos cimientos que aguantarían el fin del mundo.",
  },
  {
    title: "Estructuras de Hormigón",
    description:
      "No hacemos manualidades. Construimos el esqueleto de tu edificio para que dentro de 100 años siga en el mismo sitio.",
  },
  {
    title: "Muros y Forjados",
    description:
      "Precisión técnica para contener toneladas de presión. Lo que otros ven difícil, nosotros lo vemos como un reto.",
  },
];

const projects = [
  {
    title: "Residencial Diagonal Mar",
    location: "Barcelona",
    image: "/obra.jpeg",
    category: "Edificación",
    description:
      "Construcción integral de una torre de viviendas de lujo con acabados de alta calidad y sistemas de eficiencia energética avanzada.",
  },
  {
    title: "Sede Corporativa Tech",
    location: "Sabadell",
    image: "/obra2.jpeg",
    category: "Industria",
    description:
      "Ejecución de nave industrial de 5.000m2 con estructura reforzada para maquinaria pesada y oficinas técnicas integradas.",
  },
];
---

<style lang="scss">
  section {
    position: relative;
    padding: 100px 0;
    min-height: 100vh;

    display: flex;
    flex-direction: column;
    justify-content: center;

    &::after {
      content: "";
      position: absolute;
      left: 50%;
      bottom: 0;
      width: 100vw;
      height: 1px;
      background-color: var(--colorBorder);
      transform: translateX(-50%);
    }
  }

  h1 {
    font-size: 50px;
    color: var(--colorText);
    text-align: center;

    span {
      font-size: 70px;
      color: white;
    }
  }

  h2 {
    font-size: 20px;
    margin-top: 100px;
    text-align: center;
    color: var(--colorText2);
    text-transform: uppercase;
    font-family: var(--fontSecondary);
  }

  h3 {
    font-size: 50px;
    margin-bottom: 50px;
    color: var(--colorPrimary);
    text-align: center;
    text-transform: uppercase;
  }

  /* Hero video background */
  #inicio {
    overflow: hidden;
    position: relative;
    height: 100vh;
    padding: 0;

    .container {
      position: relative;
      z-index: 2;
      height: 100%;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
    }

    h1 {
      color: white;
      //text-shadow: 0px 0px 2px rgba(0, 0, 0, 0.4);
      margin-bottom: 50px;
    }

    h2 {
      color: rgba(255, 255, 255, 0.9);
      margin-top: 20px;
      font-weight: 300;
      letter-spacing: 0.1em;
    }

    &::before {
      content: "";
      position: absolute;
      inset: 0;
      background: linear-gradient(rgba(0, 0, 0, 0.6), rgba(0, 0, 0, 0.3));
      z-index: 1;
    }
  }

  .hero-video {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 100%;
    height: 100%;
    transform: translate(-50%, -50%);
    object-fit: cover;
    pointer-events: none;
    z-index: 0;
  }

  #filosofia {
    .content {
      display: flex;
      justify-content: space-between;
      gap: 60px;

      /* Forzar que texto e imagen ocupen 50% cada uno */
      .text,
      img {
        flex: 0 0 50%;
        max-width: 50%;
        display: flex;
        flex-direction: column;
        justify-content: center;

        h2 {
          text-align: left;
          margin-bottom: 30px;
          margin-top: 0;
        }

        span {
          color: var(--colorPrimary);
        }
      }

      /* Asegurar que la imagen escale correctamente dentro de su contenedor */
      img {
        width: 100%;
        height: auto;
        object-fit: cover;
        display: block;
      }
    }
  }

  #servicios {
    background-color: var(--colorNeutral);

    .services-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 30px;
      margin-top: 50px;

      @media (max-width: 900px) {
        grid-template-columns: 1fr;
      }
    }
  }

  .projects-grid {
    display: flex;
    flex-direction: column;
    gap: 80px;
    margin-top: 50px;
  }
</style>

<Layout title="Altamira Construcciones">
  <section id="inicio">
    <!-- Video background -->
    <video
      class="hero-video"
      autoplay
      muted
      loop
      playsinline
      poster="/default.jpeg"
    >
      <source src="/video.mp4" type="video/mp4" />
      Tu navegador no soporta la reproducción de video.
    </video>

    <div class="container g-wrapper">
      <h1>
        Las cosas bien hechas <br />
        <span> empiezan por los cimientos </span>
      </h1>
      <h2>Estructuras de hormigón para promociones residenciales</h2>
    </div>
  </section>

  <div class="g-wrapper">
    <section id="filosofia">
      <h3>Conócenos</h3>
      <div class="content">
        <img src="/default.jpeg" alt="" />

        <div class="text">
          <h2>
            Una buena obra no empieza cuando se hormigona, <span
              >empieza cuando se planifica.</span
            >
          </h2>
          <p>
            Somos una empresa familiar formada por dos generaciones dedicadas a
            la construcción.
          </p>
          <p>
            Nos especializamos en la ejecución de estructuras de hormigón para
            promociones residenciales, trabajando cada proyecto con un principio
            claro: una buena obra empieza con una buena planificación.
          </p>
          <p>
            Creemos que planificar bien no solo permite optimizar los tiempos de
            ejecución, sino también reducir costes y mejorar la organización en
            obra.
          </p>
          <p>
            Por eso analizamos cada proyecto antes de empezar, para que la
            ejecución sea ordenada, eficiente y fiable.
          </p>
        </div>
      </div>
    </section>

    <section id="servicios">
      <h3>Servicios</h3>
      <div class="services-grid">
        {
          services.map((service, index) => (
            <ServiceCard
              title={service.title}
              description={service.description}
              index={index}
            />
          ))
        }
      </div>
    </section>

    <section id="proyectos">
      <h3>Proyectos</h3>
      <div class="projects-grid">
        {
          projects
            .slice(0, 2)
            .map((project, index) => (
              <ProjectCard
                title={project.title}
                location={project.location}
                image={project.image}
                category={project.category}
                description={project.description}
                isReversed={index % 2 !== 0}
                client:load
              />
            ))
        }
      </div>
    </section>

    <section id="contacto">
      <h3>Contacto</h3>
      <ContactSection client:load />
    </section>
  </div>
</Layout>
