---
import Layout from "@/layouts/Layout.astro";
import ServiceCard from "@/components/ServiceCard.svelte";
import ProjectCard from "@/components/ProjectCard.svelte";
import ContactSection from "@/components/ContactSection.svelte";
import Collaborators from "@/components/Collaborators.svelte";

const services = [
  {
    title: "Cimentaciones",
    image: "/cimentaciones_.png",
    description:
      "Nos adaptamos a cada cimentación y ejecutamos la solución adecuada para evitar asientos, fisuras y problemas futuros. La base de una obra segura empieza aquí.",
  },
  {
    title: "Losas y muros",
    image: "/losas_y_muros.jpg",
    description:
      "Cuando hay presión, la estructura no puede fallar. Ejecutamos losas y muros preparados para soportar cargas reales y durar décadas sin problemas.",
  },
  {
    title: "Forjados y pilares",
    image: "/forjados_1.png",
    description:
      "Cada planta de un edificio se sostiene sobre un forjado. Nos encargamos de que esa base sea sólida, precisa y preparada para durar décadas sin fallos.",
  },
];

const projects = [
  {
    title: "Promoción Residencial <br/> Can Gambus",
    location: "Sabadell",
    images: [
      "/obra%20Sabadell/IMG_7501.JPEG",
      "/obra%20Sabadell/D2CCEF36-9E4B-4FF2-AF0F-A7B4432B3741.JPEG",
      "/obra%20Sabadell/IMG_7324.JPEG",
      "/obra%20Sabadell/IMG_8687.JPEG",
      "/obra%20Sabadell/D2D6318B-8F68-4598-B4ED-03BA1B87346F.JPEG",
    ],
    category: "Edificación",
    description:
      "Ejecución de estructura de hormigón en edificio plurifamiliar de 21 viviendas, incluyendo cimentación, muros y forjados. Desarrollo completo de la estructura, adaptando cada fase a las necesidades del proyecto y garantizando estabilidad y precisión en la ejecución.",
    meta: "3.455,50 m² · 6 forjados · cimentación mediante solera",
    client: "TARRACO",
  },
  {
    title: "Remodelación <br/> Oficinas Glorias",
    location: "Barcelona",
    images: [
      "/obra.jpeg",
      "/obra%20Peru/43119172-133D-4EF4-BEB5-D85B5CF8E59F.JPEG",
      "/obra%20Peru/3fb2933b-8bf4-44e7-b179-f9b74425cd67.JPEG",
      "/obra%20Peru/4b012982-38cc-45d2-b356-3a3a5b086541.JPEG",
      "/obra%20Peru/790fc56b-b03d-47bb-8027-3677206e6ee1.JPEG",
    ],
    category: "Rehabilitación",
    description:
      "Remodelación integral de oficinas con intervención sobre estructura existente, manteniendo techos de vuelta catalana y reconstruyendo soleras y forjados. Ejecución de nuevos forjados sobre estructura sin pilares, mediante vigas metálicas, con acabado de hormigón visto en todos los elementos estructurales.",
    meta: "3.515,62 m² · intervención sobre estructura existente · hormigón visto",
    client: "COPCISA",
  },
];
---

<style lang="scss">
  section {
    position: relative;
    padding: 100px 0;
    min-height: 100vh;

    display: flex;
    flex-direction: column;
    justify-content: center;

    &::after {
      content: "";
      position: absolute;
      left: 50%;
      bottom: 0;
      width: 100vw;
      height: 1px;
      background-color: var(--colorBorder);
      transform: translateX(-50%);
    }
  }

  h1 {
    font-size: 70px;
    color: var(--colorText);
    text-align: center;

    span {
      font-size: 90px;
      color: white;
    }

    @media (max-width: 1100px) {
      font-size: 36px;
      span {
        font-size: 42px;
      }
    }
  }

  h2 {
    font-size: 22px;
    text-align: center;
    color: var(--colorText3);
    text-transform: uppercase;
    font-family: var(--fontSecondary);
  }

  h3 {
    font-size: 50px;
    margin-bottom: 120px;
    color: var(--colorPrimary);
    text-align: center;
    text-transform: uppercase;

    @media (max-width: 1100px) {
      font-size: 32px;
      margin-bottom: 60px;
    }
  }

  /* Hero video background */
  #inicio {
    overflow: hidden;
    position: relative;
    height: 100vh;
    padding: 0;

    .container {
      position: relative;
      z-index: 2;
      height: 100%;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
    }

    h1 {
      color: white;
      //text-shadow: 0px 0px 2px rgba(0, 0, 0, 0.4);
      margin-bottom: 50px;
    }

    &::before {
      content: "";
      position: absolute;
      inset: 0;
      background: linear-gradient(rgba(0, 0, 0, 0.6), rgba(0, 0, 0, 0.3));
      z-index: 1;
    }
  }

  .hero-video {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 100%;
    height: 100%;
    transform: translate(-50%, -50%);
    object-fit: cover;
    pointer-events: none;
    z-index: 0;
  }

  #filosofia {
    .content {
      display: flex;
      justify-content: space-between;
      gap: 60px;

      @media (max-width: 1100px) {
        flex-direction: column;
        gap: 40px;
      }

      /* Forzar que texto e imagen ocupen 50% cada uno */
      .text,
      img {
        flex: 1;
        max-width: 50%;
        display: flex;
        flex-direction: column;
        justify-content: center;

        @media (max-width: 1100px) {
          max-width: 100%;
        }

        span {
          color: var(--colorPrimary);
        }
      }

      /* Asegurar que la imagen escale correctamente dentro de su contenedor */
      img {
        width: 100%;
        height: auto;
        object-fit: cover;
        display: block;
      }
    }

    h5 {
      font-family: var(--fontSecondary);
      font-size: 20px;
      font-weight: bold;

      @media (max-width: 1100px) {
        font-size: 18px;
      }
    }

    h4 {
      margin-top: 50px;
      text-align: center;
      font-size: 24px;
      font-family: var(--fontSecondary);
      font-weight: 500;
      color: var(--colorText2);

      @media (max-width: 1100px) {
        font-size: 18px;
        margin-top: 40px;
      }

      span {
        color: var(--colorPrimary);
      }
    }
  }

  #servicios {
    background-color: var(--colorNeutral);

    .services-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 30px;

      @media (max-width: 1100px) {
        grid-template-columns: 1fr;
      }
    }
  }

  .projects-grid {
    display: flex;
    flex-direction: column;
    gap: 150px;
  }

  #galeria {
    padding: 100px 0;
    min-height: auto;

    h3 {
      margin-bottom: 60px;
    }

    &::after {
      display: none;
    }
  }

  p {
    text-align: justify;
  }
</style>

<Layout title="Altamira Construcciones">
  <section id="inicio">
    <!-- Video background -->
    <video
      class="hero-video"
      autoplay
      muted
      loop
      playsinline
      poster="/default.jpeg"
    >
      <source src="/video.mp4" type="video/mp4" />
      Tu navegador no soporta la reproducción de video.
    </video>

    <div class="container g-wrapper">
      <h1>
        Las cosas bien hechas <br />
        <span> empiezan por los cimientos </span>
      </h1>
      <h2>Estructuras de hormigón para promociones residenciales</h2>
    </div>
  </section>

  <div class="g-wrapper">
    <section id="filosofia">
      <h3>Conócenos</h3>
      <div class="content">
        <img src="/default.jpeg" alt="" />

        <div class="text">
          <h5>Empresa familiar, implicación directa en cada obra</h5>

          <br />
          <p>
            Altamira construcciones es una empresa familiar formada por dos
            generaciones dedicadas a la construcción.
          </p>
          <p>
            Nos especializamos en la ejecución de estructuras de hormigón para
            promociones residenciales, trabajando cada proyecto con un principio
            claro: una buena obra empieza con una buena planificación.
          </p>
          <p>
            Creemos que planificar bien no solo permite optimizar los tiempos de
            ejecución, sino también reducir costes y mejorar la organización en
            obra.
          </p>
          <p>
            Por eso analizamos cada proyecto antes de empezar, para que la
            ejecución sea ordenada, eficiente y fiable.
          </p>
        </div>
      </div>

      <h4>
        Una buena obra no empieza cuando se hormigona, <br />
        <span>empieza cuando se planifica.</span>
      </h4>
    </section>

    <section id="servicios">
      <h3>Servicios</h3>
      <div class="services-grid">
        {
          services.map((service, index) => (
            <ServiceCard
              title={service.title}
              image={service.image}
              description={service.description}
              index={index}
            />
          ))
        }
      </div>
    </section>

    <section id="proyectos">
      <h3>Algunos proyectos</h3>
      <div class="projects-grid">
        {
          projects
            .slice(0, 2)
            .map((project, index) => (
              <ProjectCard
                title={project.title}
                location={project.location}
                images={project.images}
                category={project.category}
                description={project.description}
                meta={project.meta}
                client={project.client}
                isReversed={index % 2 !== 0}
                client:load
              />
            ))
        }
      </div>
    </section>

    <section id="contacto">
      <h3>Contacto</h3>
      <ContactSection client:load />
    </section>
  </div>
</Layout>
